# macOS.Gaslight - Telegram Bot API C2 Communication (Suricata 7.x)
# Reference: https://www.sentinelone.com/labs/macos-gaslight-rust-backdoor-turns-prompt-injection-on-the-analyst-not-the-sandbox/
# Author: Actioner CTI
# Date: 2026-06-25

# Detects Telegram Bot API getUpdates polling (primary C2 mechanism)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"MALWARE macOS.Gaslight - Telegram Bot API C2 getUpdates polling"; tls.sni; content:"api.telegram.org"; nocase; sid:2026062501; rev:1; metadata:created_at 2026_06_25, severity 3; classtype:trojan-activity; reference:url,www.sentinelone.com/labs/macos-gaslight-rust-backdoor-turns-prompt-injection-on-the-analyst-not-the-sandbox/;)

# Detects repeated TLS connections to Telegram API (behavioral anomaly)
alert tls $HOME_NET any -> $EXTERNAL_NET 443 (msg:"MALWARE macOS.Gaslight - Telegram Bot API TLS Connection"; tls.sni; content:"api.telegram.org"; nocase; threshold:type both, track by_src, count 10, seconds 60; sid:2026062502; rev:1; metadata:created_at 2026_06_25, severity 4; classtype:policy-violation; reference:url,www.sentinelone.com/labs/macos-gaslight-rust-backdoor-turns-prompt-injection-on-the-analyst-not-the-sandbox/;)

# Detects Python standalone runtime download from astral-sh GitHub
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"MALWARE macOS.Gaslight - Python Runtime Staging Download from astral-sh"; tls.sni; content:"github.com"; nocase; flow:established,to_server; sid:2026062503; rev:1; metadata:created_at 2026_06_25, severity 4; classtype:trojan-activity; reference:url,www.sentinelone.com/labs/macos-gaslight-rust-backdoor-turns-prompt-injection-on-the-analyst-not-the-sandbox/;)
