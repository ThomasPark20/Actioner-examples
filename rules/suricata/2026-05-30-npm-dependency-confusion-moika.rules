# npm dependency-confusion "moika.tech" campaign — network C2 (Suricata)
# Source: https://www.microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Actioner - npm-depconf moika.tech stager C2 X-Secret header"; flow:to_server,established; http.header; content:"X-Secret|3a 20|l95HdDaz3kQx1Zsg3WxH6HvKANf51RY1"; fast_pattern; classtype:trojan-activity; reference:url,microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/; metadata:author Actioner, created_at 2026-05-30; sid:2200601; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Actioner - npm-depconf moika.tech C2 HTTP Host"; flow:to_server,established; http.host; content:"oob.moika.tech"; bsize:14; classtype:trojan-activity; reference:url,microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/; metadata:author Actioner, created_at 2026-05-30; sid:2200602; rev:1;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"Actioner - npm-depconf moika.tech C2 TLS SNI"; flow:to_server,established; tls.sni; content:"oob.moika.tech"; bsize:14; classtype:trojan-activity; reference:url,microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/; metadata:author Actioner, created_at 2026-05-30; sid:2200603; rev:1;)
alert dns $HOME_NET any -> any any (msg:"Actioner - npm-depconf moika.tech C2 DNS query"; dns.query; content:"oob.moika.tech"; bsize:14; classtype:trojan-activity; reference:url,microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/; metadata:author Actioner, created_at 2026-05-30; sid:2200604; rev:1;)
