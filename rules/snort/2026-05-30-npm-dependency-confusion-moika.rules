# npm dependency-confusion "moika.tech" campaign — network C2 (Snort 2.9)
# Source: https://www.microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (msg:"ACTIONER npm-depconf moika.tech stager C2 X-Secret header"; flow:to_server,established; content:"X-Secret|3a 20|l95HdDaz3kQx1Zsg3WxH6HvKANf51RY1"; http_header; fast_pattern; classtype:trojan-activity; reference:url,microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/; sid:2100601; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (msg:"ACTIONER npm-depconf moika.tech C2 Host header"; flow:to_server,established; content:"Host|3a 20|oob.moika.tech"; http_header; nocase; classtype:trojan-activity; reference:url,microsoft.com/en-us/security/blog/2026/05/29/33-malicious-npm-packages-abuse-dependency-confusion-profile-developer-environments/; sid:2100602; rev:1;)
